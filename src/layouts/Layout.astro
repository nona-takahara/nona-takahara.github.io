---
import BaseLayout from "@layouts/BaseLayout.astro";
import type { OgPageType } from "./Og";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";

interface Props {
  katex?: boolean;
  titleShort?: string;
  titleSuffix?: string;
  description: string;
  pageType: OgPageType;
  highlight?: boolean;
}

const {
  katex = false,
  titleShort = "",
  titleSuffix = " | こーげんやさい",
  description,
  pageType,
  highlight = false,
} = Astro.props;
---

<BaseLayout
  titleShort={titleShort}
  titleSuffix={titleSuffix || " | こーげんやさい"}
  katex={katex}
  description={description}
  pageType={pageType}
  highlight={highlight}
>
  <Navbar />
  <slot />
  <Footer />
</BaseLayout>
